<?xml version="1.0" encoding="UTF-8"?>

<!-- https://phpunit.readthedocs.io/en/latest/configuration.html -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         colors="true"
         failOnDeprecation="true"
         failOnNotice="true"
         failOnWarning="true"
         bootstrap="tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="-1" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="KERNEL_CLASS" value="App\Kernel" force="true" />
        <server name="SHELL_VERBOSITY" value="-1" />
    </php>

    <testsuites>
        <testsuite name="Unit">
            <file>tests/App/KernelTest.php</file>
            <directory>tests/VendingMachine/Application</directory>
            <directory>tests/VendingMachine/Domain</directory>
            <directory>tests/VendingMachine/Infrastructure/Persistence/MongoDB/Machine/Document</directory>
            <directory>tests/VendingMachine/Infrastructure/Persistence/MongoDB/Machine/Mapper</directory>
            <file>tests/VendingMachine/Infrastructure/Symfony/Command/SeedDefaultMachineCommandTest.php</file>
            <file>tests/VendingMachine/Infrastructure/Symfony/Controller/Api/MachineControllerDirectTest.php</file>
            <file>tests/VendingMachine/Infrastructure/Symfony/Controller/Api/MachineJsonRequestFactoryTest.php</file>
            <file>tests/VendingMachine/Infrastructure/Symfony/Controller/Api/MachineJsonResponseFactoryTest.php</file>
        </testsuite>

        <testsuite name="Integration">
            <directory>tests/VendingMachine/Infrastructure/Persistence/MongoDB/Machine/Integration</directory>
            <file>tests/VendingMachine/Infrastructure/Symfony/Controller/Api/MachineControllerTest.php</file>
        </testsuite>

    </testsuites>

    <source ignoreSuppressionOfDeprecations="true"
            ignoreIndirectDeprecations="true"
            restrictNotices="true"
            restrictWarnings="true"
    >
        <include>
            <directory>src/VendingMachine</directory>
        </include>

        <exclude>
            <directory>src/VendingMachine/Infrastructure/Symfony/Command</directory>
            <directory>src/VendingMachine/Domain/Machine/Exception</directory>
            <file>src/Kernel.php</file>
        </exclude>

        <deprecationTrigger>
            <method>Doctrine\Deprecations\Deprecation::trigger</method>
            <method>Doctrine\Deprecations\Deprecation::delegateTriggerToBackend</method>
            <function>trigger_deprecation</function>
        </deprecationTrigger>
    </source>

    <extensions>
    </extensions>
</phpunit>
